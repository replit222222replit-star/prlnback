# Groq API
# Получить: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Bot
# Создать бота: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Username бота без @ (нужен для deep link в приложении)
BOT_USERNAME=neo_genesis_auth_bot

# Telegram ID кто может авторизоваться
# Узнать свой ID: https://t.me/userinfobot
ALLOWED_TELEGRAM_IDS=123456789

# JWT подпись — любая случайная строка
JWT_SECRET=neo_genesis_2026_замени_на_своё

# Порт (Railway выставляет сам)
PORT=5000
